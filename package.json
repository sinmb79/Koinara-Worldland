{
  "name": "koinara-worldland",
  "private": true,
  "type": "module",
  "workspaces": [
    "node"
  ],
  "scripts": {
    "ci:sanity": "tsx scripts/ci-sanity.ts",
    "build": "npm run typecheck:scripts && npm run build --workspace node",
    "setup": "npm run setup --workspace node",
    "node": "npm run start --workspace node",
    "node:once": "npm run start:once --workspace node",
    "node:doctor": "npm run doctor --workspace node",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "typecheck": "npm run typecheck:scripts && npm run typecheck --workspace node",
    "doctor:testnet": "tsx deploy/doctor.ts --profile testnet",
    "doctor:mainnet": "tsx deploy/doctor.ts --profile mainnet",
    "deploy:testnet": "tsx deploy/deploy.ts --profile testnet",
    "deploy:mainnet": "tsx deploy/deploy.ts --profile mainnet",
    "deploy:v2:testnet": "tsx deploy/deploy-v2.ts --profile testnet",
    "deploy:v2:mainnet": "tsx deploy/deploy-v2.ts --profile mainnet",
    "verify:testnet": "tsx deploy/verify.ts --profile testnet",
    "verify:mainnet": "tsx deploy/verify.ts --profile mainnet",
    "verify:v2:testnet": "tsx deploy/verify-v2.ts --profile testnet",
    "verify:v2:mainnet": "tsx deploy/verify-v2.ts --profile mainnet",
    "canary:testnet": "tsx deploy/canary.ts --profile testnet",
    "canary:mainnet": "tsx deploy/canary.ts --profile mainnet",
    "canary:v2:testnet": "tsx deploy/canary.ts --profile testnet",
    "canary:v2:mainnet": "tsx deploy/canary.ts --profile mainnet",
    "rehearse:v2:local": "powershell -ExecutionPolicy Bypass -File scripts/rehearse-v2-local.ps1",
    "e2e": "tsx deploy/e2e.ts"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
